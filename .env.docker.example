# RLM-Tools-BSL Docker Environment Configuration
# Copy this to .env and customize for your setup

# ============================================================================
# Core Server Settings
# ============================================================================

# Maximum concurrent sessions (default: 5)
RLM_MAX_SESSIONS=5

# Session timeout in minutes (default: 10)
RLM_SESSION_TIMEOUT=10

# Index directory location (default: next to service.json)
# In Docker: use /data/.rlm-index or similar
RLM_INDEX_DIR=/data/.rlm-index

# ============================================================================
# LLM Query Settings (Optional)
# Required only if using llm_query() helper in sandbox
# ============================================================================

# Anthropic API (for llm_query calls)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API (for llm_query calls)
# OPENAI_API_KEY=sk-...

# Alternative LLM endpoint (OpenRouter, Ollama, vLLM, etc.)
# RLM_LLM_QUERY_ENDPOINT=https://openrouter.ai/api/v1
# RLM_LLM_QUERY_MODEL=openrouter/meta-llama/llama-2-70b
# RLM_LLM_QUERY_API_KEY=sk-...

# LLM query batch size (default: 5)
# RLM_LLM_QUERY_BATCH_SIZE=5

# LLM query timeout in seconds (default: 30)
# RLM_LLM_QUERY_TIMEOUT=30

# ============================================================================
# Logging
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
# LOG_LEVEL=INFO

# ============================================================================
# Project Registry
# ============================================================================

# Path to projects.json (default: next to service.json)
# RLM_PROJECTS_FILE=/data/projects.json

# ============================================================================
# Performance Tuning
# ============================================================================

# Glob timeout in seconds (default: 30)
# RLM_GLOB_TIMEOUT=30

# Tree operation timeout in seconds (default: 60)
# RLM_TREE_TIMEOUT=60

# Read file timeout in seconds (default: 10)
# RLM_READ_TIMEOUT=10

# Max file size for reading in bytes (default: 5MB)
# RLM_MAX_FILE_SIZE=5242880

# ============================================================================
# Advanced (rarely needed)
# ============================================================================

# Enable stateless HTTP mode (required for MCP)
# RLM_STATELESS_HTTP=true

# Custom service.json location
# RLM_SERVICE_JSON=/data/service.json

# Disable LLM query warmup (speeds up startup if not using llm_query)
# RLM_SKIP_LLM_WARMUP=true
